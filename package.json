{
	"name": "@gjbkz/gojabako.zone",
	"homepage": "https://gojabako.zone/",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"test": "run-s test:*",
		"test:type": "tsc --noEmit",
		"test:unit": "node --test \"src/**/*.test.ts\"",
		"e2e": "playwright test",
		"dev": "run-p build:meta page-list dev:*",
		"dev:css": "node src/cli/cssTypes.ts --watch",
		"dev:stories": "node src/cli/stories.ts --watch",
		"dev:next": "next --webpack",
		"https": "run-p build:meta dev:css dev:stories https:*",
		"https:next": "node server.ts",
		"build": "run-s build:*",
		"build:meta": "run-p build:meta:*",
		"build:meta:version": "node src/cli/version.ts",
		"build:meta:fonts": "node src/cli/fonts.ts",
		"build:meta:cssTypes": "node src/cli/cssTypes.ts",
		"build:meta:stories": "node src/cli/stories.ts",
		"build:next": "next build --webpack",
		"page-list": "node src/cli/pageList.ts",
		"start": "next start",
		"lint": "npx @biomejs/biome check",
		"format": "npx @biomejs/biome check --write",
		"encrypt-env": "dotenvx encrypt"
	},
	"dependencies": {
		"@fontsource/noto-sans-jp": "5.2.9",
		"@mdx-js/loader": "3.1.1",
		"@next/mdx": "16.2.1",
		"@nlib/typing": "3.0.4",
		"@opentelemetry/otlp-transformer": "0.214.0",
		"@opentelemetry/sdk-logs": "0.214.0",
		"@storybook/csf": "0.1.13",
		"@svgr/webpack": "8.1.0",
		"@types/kuromoji": "0.1.3",
		"@types/node": "25.5.0",
		"@types/react": "19.2.14",
		"acorn": "8.16.0",
		"chokidar": "5.0.0",
		"hast-util-from-html": "2.0.3",
		"hast-util-to-string": "3.0.1",
		"jotai": "2.19.0",
		"kuromoji": "0.1.2",
		"lowlight": "3.3.0",
		"mdast-util-from-markdown": "2.0.3",
		"mdast-util-to-hast": "13.2.1",
		"mdast-util-to-string": "4.0.0",
		"next": "16.1.6",
		"npm-run-all2": "8.0.4",
		"postcss": "8.5.8",
		"postcss-selector-parser": "7.1.1",
		"rehype-highlight": "7.0.2",
		"rehype-katex": "7.0.1",
		"rehype-parse": "9.0.1",
		"rehype-slug": "6.0.0",
		"remark-gfm": "4.0.1",
		"remark-math": "6.0.0",
		"sass": "1.98.0",
		"sharp": "0.34.5",
		"typescript": "5.9.3",
		"unist-util-find": "3.0.0",
		"unist-util-visit": "5.1.0",
		"vlq": "2.0.4"
	},
	"renovate": {
		"extends": [
			"github>nlibjs/renovate-config"
		],
		"ignoreDeps": [
			"next"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.9",
		"@nlib/githooks": "0.2.2",
		"@playwright/test": "1.58.2",
		"baseline-browser-mapping": "2.10.11"
	}
}
